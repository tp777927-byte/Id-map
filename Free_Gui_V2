    PresetRow.BackgroundTransparency = 1

    local presetColors = {
        Color3.fromRGB(0,255,0),
        Color3.fromRGB(255,50,50),
        Color3.fromRGB(50,120,255),
        Color3.fromRGB(255,200,0),
        Color3.fromRGB(200,0,255),
        Color3.fromRGB(0,220,220),
        Color3.fromRGB(255,120,0),
        Color3.fromRGB(255,255,255),
    }

    local H, S, V = 0, 1, 1
    do
        H, S, V = Color3.toHSV(currentColor)
    end

    local function colorToHex(c)
        return string.format("#%02X%02X%02X",
            math.round(c.R * 255),
            math.round(c.G * 255),
            math.round(c.B * 255)
        )
    end

    local function applyColor(color)
        currentColor = color
        ColorPreview.BackgroundColor3 = color
        PickerStroke.Color = color
        HexBox.Text = colorToHex(color)
        callback(color)
    end

    local function updateFromHSV()
        SVFrame.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
        local color = Color3.fromHSV(H, S, V)
        applyColor(color)
        SVCursor.Position = UDim2.new(S, 0, 1 - V, 0)
        HueCursor.Position = UDim2.new(H, 0, 0.5, 0)
    end

    local svDragging = false
    SVFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
            local rel = input.Position
            S = math.clamp((rel.X - SVFrame.AbsolutePosition.X) / SVFrame.AbsoluteSize.X, 0, 1)
            V = 1 - math.clamp((rel.Y - SVFrame.AbsolutePosition.Y) / SVFrame.AbsoluteSize.Y, 0, 1)
            updateFromHSV()
        end
    end)
    SVFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = false end
    end)

    local hueDragging = false
    HueBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
            H = math.clamp((input.Position.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 0.999)
            updateFromHSV()
        end
    end)
    HueBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = false end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            if svDragging then
                S = math.clamp((input.Position.X - SVFrame.AbsolutePosition.X) / SVFrame.AbsoluteSize.X, 0, 1)
                V = 1 - math.clamp((input.Position.Y - SVFrame.AbsolutePosition.Y) / SVFrame.AbsoluteSize.Y, 0, 1)
                updateFromHSV()
            end
            if hueDragging then
                H = math.clamp((input.Position.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 0.999)
                updateFromHSV()
            end
        end
    end)

    HexBox.FocusLost:Connect(function()
        local hex = HexBox.Text:gsub("#","")
        if #hex == 6 then
            local r = tonumber(hex:sub(1,2), 16)
            local g = tonumber(hex:sub(3,4), 16)
            local b = tonumber(hex:sub(5,6), 16)
            if r and g and b then
                local color = Color3.fromRGB(r, g, b)
                H, S, V = Color3.toHSV(color)
                updateFromHSV()
            end
        end
    end)

    for i, preset in ipairs(presetColors) do
        local dot = Instance.new("TextButton")
        dot.Parent = PresetRow
        dot.Size = UDim2.new(0, 20, 0, 20)
        dot.Position = UDim2.new(0, (i-1) * 26, 0, 0)
        dot.BackgroundColor3 = preset
        dot.BorderSizePixel = 0
        dot.Text = ""
        dot.AutoButtonColor = false
        local dc = Instance.new("UICorner")
        dc.CornerRadius = UDim.new(0, 5)
        dc.Parent = dot
        dot.MouseButton1Click:Connect(function()
            H, S, V = Color3.toHSV(preset)
            updateFromHSV()
        end)
        dot.MouseEnter:Connect(function()
            TweenService:Create(dot, TweenInfo.new(0.15), {Size = UDim2.new(0, 24, 0, 24)}):Play()
        end)
        dot.MouseLeave:Connect(function()
            TweenService:Create(dot, TweenInfo.new(0.15), {Size = UDim2.new(0, 20, 0, 20)}):Play()
        end)
    end

    updateFromHSV()

    function pickerFunc:Open()
        PickerGui.Enabled = true
    end

    function pickerFunc:Close()
        PickerGui.Enabled = false
    end

    function pickerFunc:Toggle()
        PickerGui.Enabled = not PickerGui.Enabled
    end

    function pickerFunc:SetColor(color)
        H, S, V = Color3.toHSV(color)
        updateFromHSV()
    end

    return pickerFunc
end

-- ============================================================
-- ApplyColor
-- ============================================================
function library:ApplyColor(color)
    _G.Color = color
    for _, screen in ipairs({UI}) do
        for _, obj in ipairs(screen:GetDescendants()) do
            if obj:IsA("UIStroke") and obj.Name == "" then
                pcall(function() obj.Color = color end)
            end
            if obj:IsA("TextLabel") and obj.Name == "Sectionname" then
                pcall(function() obj.TextColor3 = color end)
            end
            if obj:IsA("TextLabel") and obj.Name == "Title2" then
                pcall(function() obj.TextColor3 = color end)
            end
            if obj:IsA("Frame") and obj.Name == "FrameTab" then
                pcall(function() obj.BackgroundColor3 = color end)
            end
            if obj:IsA("Frame") and obj.Name == "Button" then
                pcall(function() obj.BackgroundColor3 = color end)
            end
            if obj:IsA("Frame") and obj.Name == "MainValue" then
                pcall(function() obj.BackgroundColor3 = color end)
            end
            if obj:IsA("Frame") and obj.Name == "ConneValue" then
                pcall(function() obj.BackgroundColor3 = color end)
            end
            if obj:IsA("Frame") and (obj.Name == "Label22" or obj.Name == "Label23") then
                pcall(function() obj.BackgroundColor3 = color end)
            end
            if obj:IsA("UIStroke") and obj.Parent and obj.Parent:IsA("TextBox") then
                pcall(function() obj.Color = color end)
            end
            if obj:IsA("TextLabel") and obj.Name == "Text" and obj.Parent and obj.Parent.Name == "Textbox" then
                pcall(function() obj.TextColor3 = color end)
            end
        end
    end
end

-- ============================================================
-- CreateToggleGui — ปุ่ม floating สำหรับมือถือ (tap ได้เลย)
-- รองรับทั้ง PC (hover animation) และ Mobile (tap to toggle)
-- ไม่ใช้ VirtualInputManager หรือ KeyCode อีกต่อไป
-- ============================================================
function library:CreateToggleGui(logo)
    local ToggleGui = Instance.new("ScreenGui")
    ToggleGui.Name = "AttackHub_ToggleGui"
    ToggleGui.Parent = game.CoreGui
    ToggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- Shadow
    local Shadow = Instance.new("Frame")
    Shadow.Parent = ToggleGui
    Shadow.AnchorPoint = Vector2.new(0.5, 0.5)
    Shadow.Position = UDim2.new(0, 80, 0, 80)
    Shadow.Size = UDim2.new(0, 55, 0, 55)
    Shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Shadow.BackgroundTransparency = 0.5
    Shadow.BorderSizePixel = 0
    local ShadowCorner = Instance.new("UICorner")
    ShadowCorner.CornerRadius = UDim.new(0, 100)
    ShadowCorner.Parent = Shadow

    -- Main Button (ใช้ TextButton แทน ImageButton เพื่อ Touch support ที่ดีขึ้น)
    local ToggleBtn = Instance.new("ImageButton")
    ToggleBtn.Name = "AttackHubToggle"
    ToggleBtn.Parent = ToggleGui
    ToggleBtn.AnchorPoint = Vector2.new(0.5, 0.5)
    ToggleBtn.Position = UDim2.new(0, 80, 0, 80)
    ToggleBtn.Size = UDim2.new(0, 50, 0, 50)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(11, 12, 13)
    ToggleBtn.BackgroundTransparency = 0
    ToggleBtn.BorderSizePixel = 0
    ToggleBtn.AutoButtonColor = false
    ToggleBtn.Image = "rbxassetid://" .. tostring(logo or _G.Logo or 13732317842)
    ToggleBtn.ScaleType = Enum.ScaleType.Fit

    -- รองรับ drag บนมือถือด้วย
    ToggleBtn.Draggable = false  -- ปิด built-in draggable เพราะจะทำ custom drag แทน

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 100)
    BtnCorner.Parent = ToggleBtn

    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Thickness = 2.5
    BtnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    BtnStroke.Color = _G.Color or Color3.fromRGB(0, 255, 0)
    BtnStroke.Transparency = 0.1
    BtnStroke.Parent = ToggleBtn

    -- ============================================================
    -- Custom Drag สำหรับปุ่ม floating (รองรับ Touch + Mouse)
    -- ============================================================
    local btnDragging = false
    local btnDragStart = nil
    local btnStartPos = nil
    local btnMoved = false  -- ตรวจว่า tap หรือ drag

    ToggleBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            btnDragging = true
            btnMoved = false
            btnDragStart = input.Position
            btnStartPos = ToggleBtn.Position
        end
    end)

    ToggleBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            btnDragging = false
            -- ถ้าไม่ได้ลาก (btnMoved = false) ให้ toggle GUI
            if not btnMoved then
                -- Tap animation
                TweenService:Create(ToggleBtn, TweenInfo.new(0.15, Enum.EasingStyle.Back), {
                    Rotation = 180
                }):Play()
                TweenService:Create(BtnStroke, TweenInfo.new(0.15), {
                    Transparency = 0.5
                }):Play()
                task.wait(0.2)
                TweenService:Create(ToggleBtn, TweenInfo.new(0.15, Enum.EasingStyle.Back), {
                    Rotation = 0
                }):Play()
                TweenService:Create(BtnStroke, TweenInfo.new(0.15), {
                    Transparency = 0.1
                }):Play()

                -- Toggle GUI โดยตรง ไม่ผ่าน keyboard เลย
                _toggleMainGui()
            end
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if btnDragging and (
            input.UserInputType == Enum.UserInputType.MouseMovement or
            input.UserInputType == Enum.UserInputType.Touch
        ) then
            local delta = input.Position - btnDragStart
            -- ถ้าเคลื่อนที่มากกว่า 5px ถือว่าเป็น drag ไม่ใช่ tap
            if delta.Magnitude > 5 then
                btnMoved = true
            end
            if btnMoved then
                local newPos = UDim2.new(
                    btnStartPos.X.Scale,
                    btnStartPos.X.Offset + delta.X,
                    btnStartPos.Y.Scale,
                    btnStartPos.Y.Offset + delta.Y
                )
                ToggleBtn.Position = newPos
            end
        end
    end)

    -- Hover animation (PC เท่านั้น — มือถือไม่มี MouseEnter)
    ToggleBtn.MouseEnter:Connect(function()
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.InOut), {
            Size = UDim2.new(0, 70, 0, 70)
        }):Play()
        TweenService:Create(Shadow, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.InOut), {
            Size = UDim2.new(0, 75, 0, 75),
            BackgroundTransparency = 0.6
        }):Play()
    end)

    ToggleBtn.MouseLeave:Connect(function()
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.InOut), {
            Size = UDim2.new(0, 50, 0, 50)
        }):Play()
        TweenService:Create(Shadow, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.InOut), {
            Size = UDim2.new(0, 55, 0, 55),
            BackgroundTransparency = 0.5
        }):Play()
    end)

    -- Sync shadow ตาม button
    RunService.Heartbeat:Connect(function()
        pcall(function()
            Shadow.Position = ToggleBtn.Position
        end)
    end)

    local toggleGuiFunc = {}

    function toggleGuiFunc:SetVisible(state)
        ToggleGui.Enabled = state
    end

    function toggleGuiFunc:UpdateColor(color)
        BtnStroke.Color = color
    end

    function toggleGuiFunc:UpdateLogo(assetId)
        ToggleBtn.Image = "rbxassetid://" .. tostring(assetId)
    end

    return toggleGuiFunc
end

-- ============================================================
-- Settings API
-- ============================================================
function library:Settings(toggleGuiRef)
    local cfg = {}

    function cfg:SetGuiColor(color)
        _G.Color = color
        library:ApplyColor(color)
        if toggleGuiRef and toggleGuiRef.UpdateColor then
            toggleGuiRef:UpdateColor(color)
        end
    end

    function cfg:SetToggleColor(toggleFunc, color)
        if toggleFunc and toggleFunc.SetColor then
            toggleFunc:SetColor(color)
        end
    end

    function cfg:SetLogo(assetId)
        if toggleGuiRef and toggleGuiRef.UpdateLogo then
            toggleGuiRef:UpdateLogo(assetId)
        end
    end

    function cfg:SetSound(openId, closeId, volume)
        local ss = game:GetService("SoundService")
        local vol = volume or 0.5
        local sOpen  = ss:FindFirstChild("AttackHub_Open")
        local sClose = ss:FindFirstChild("AttackHub_Close")
        if sOpen  and openId  then sOpen.SoundId  = "rbxassetid://" .. tostring(openId)  sOpen.Volume  = vol end
        if sClose and closeId then sClose.SoundId = "rbxassetid://" .. tostring(closeId) sClose.Volume = vol end
    end

    function cfg:SetVolume(volume)
        local ss = game:GetService("SoundService")
        local sOpen  = ss:FindFirstChild("AttackHub_Open")
        local sClose = ss:FindFirstChild("AttackHub_Close")
        if sOpen  then sOpen.Volume  = volume end
        if sClose then sClose.Volume = volume end
    end

    return cfg
end

-- ============================================================
-- Export
-- ============================================================
return library
