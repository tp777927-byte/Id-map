-- ============================================================
-- Internal toggle state (shared ระหว่าง keyboard และปุ่มมือถือ)
-- ============================================================
local _guiVisible = true  -- เริ่มต้น GUI เปิดอยู่
local _mainFrameRef = nil -- เก็บ ref ของ Main frame เพื่อ toggle

local function _toggleMainGui()
	if _mainFrameRef == nil then return end
	local SoundService = game:GetService("SoundService")
	local sOpen  = SoundService:FindFirstChild("AttackHub_Open")
	local sClose = SoundService:FindFirstChild("AttackHub_Close")

	if _guiVisible then
		-- ซ่อน GUI
		pcall(function() if sClose then sClose:Play() end end)
		_mainFrameRef:TweenSize(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.4, true)
		task.wait(0.4)
		UI.Enabled = false
		_guiVisible = false
	else
		-- แสดง GUI
		UI.Enabled = true
		pcall(function() if sOpen then sOpen:Play() end end)
		_mainFrameRef:TweenSize(UDim2.new(0, 585, 0, 400), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.4, true)
		_guiVisible = true
	end
end

